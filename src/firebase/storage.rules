rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if the user is an admin
    function isAdmin() {
      return request.auth != null && (
        firestore.exists(/databases/(default)/documents/roles_admin/$(request.auth.uid)) ||
        (firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) && 
         firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin']))
      );
    }

    match /public-uploads {
      // Global read access for all public uploads
      allow read: if true;

      // Avatar uploads: Users can only upload their own, and it must be an image < 2MB
      match /avatars/{userId}/{fileName} {
        allow write: if request.auth != null && request.auth.uid == userId
                     && request.resource.size < 2 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
      }
      
      // Ticket background uploads: Vendors can only upload their own, and it must be an image < 5MB
      match /ticket-assets/{userId}/{fileName} {
        allow write: if request.auth != null && request.auth.uid == userId
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
      }
      
      // Admin shared assets: Only admins can manage these
      match /admin-assets/{allPaths=**} {
        allow write: if isAdmin()
                     && request.resource.size < 5 * 1024 * 1024
                     && request.resource.contentType.matches('image/.*');
      }
    }

    // Default deny for all other paths not explicitly allowed above
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
