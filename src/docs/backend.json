
{
  "entities": {
    "Event": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Event",
      "type": "object",
      "description": "Represents an event shell created by a vendor. All ticket and pricing logic is handled by the Ticket entity.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the event." },
        "vendorId": { "type": "string", "description": "ID of the vendor who created the event." },
        "name": { "type": "string", "description": "Name of the event." },
        "description": { "type": "string", "description": "Description of the event." },
        "date": { "type": "string", "description": "Date of the event.", "format": "date-time" },
        "location": { "type": "string", "description": "Location of the event." },
        "bannerUrl": { "type": "string", "description": "URL for the event's banner image." },
        "isPrivate": { "type": "boolean", "description": "If true, the event is not listed publicly." },
        "authorizedScanners": { "type": "array", "items": { "type": "string" }, "description": "A list of user IDs authorized to scan tickets for this event." },
        "status": { "type": "string", "description": "The status of the event.", "enum": ["published", "draft"]}
      },
      "required": ["id", "vendorId", "name", "date", "location", "status"]
    },
    "Ticket": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ticket",
      "type": "object",
      "description": "Represents a single crafted ticket, linked to an event, with all its design and validation rules.",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the ticket." },
        "eventId": { "type": "string", "description": "ID of the event this ticket belongs to." },
        "vendorId": { "type": "string", "description": "ID of the vendor for authorization." },
        "userId": { "type": "string", "description": "ID of the user who owns the ticket (can be assigned later)." },
        "purchaseDate": { "type": "string", "format": "date-time" },
        "price": { "type": "number", "description": "Price paid by the end-user for the ticket (can be 0 for free)." },
        "package": { "type": "string", "enum": ["Regular", "Premium Individual", "Premium General", "Tiered"] },
        "tier": { "type": "string", "enum": ["Tier 1", "Tier 2", "Tier 3", "Tier 4", "Tier 5"] },
        "templateId": { "type": "string" },
        "ticketImageUrl": { "type": "string" },
        "ticketBrandingImageUrl": { "type": "string" },
        "guestPhotoUrl": { "type": "string" },
        "class": { "type": "string", "enum": ["Regular", "VIP", "VVIP"] },
        "attendeeName": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "scans": { "type": "number", "description": "How many times the ticket has been scanned." },
        "maxScans": { "type": "number", "description": "Maximum number of allowed scans." },
        "lastScannedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "vendorId", "purchaseDate", "package", "scans", "maxScans"]
    },
    "UserTicket": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserTicket",
      "type": "object",
      "description": "A denormalized reference to a Ticket, stored under a user's collection for easy lookup.",
      "properties": {
          "ticketId": { "type": "string" },
          "eventId": { "type": "string" },
          "purchaseDate": { "type": "string", "format": "date-time" },
          "userId": { "type": "string" },
          "vendorId": { "type": "string" }
      },
      "required": ["ticketId", "eventId", "userId", "vendorId"]
    },
    "Vendor": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Vendor",
      "type": "object",
      "description": "Represents a vendor who creates events and tickets.",
      "properties": {
        "id": { "type": "string" }, "name": { "type": "string" }, "email": { "type": "string", "format": "email" }
      },
      "required": ["id", "name", "email"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" }, "firstName": { "type": "string" }, "lastName": { "type": "string" }, "email": { "type": "string", "format": "email" }, "roles": { "type": "array", "items": { "type": "string", "enum": ["user", "vendor", "admin"] } }
      },
      "required": ["id", "firstName", "lastName", "email", "roles"]
    },
    "Admin": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Admin",
      "type": "object",
      "properties": { "id": { "type": "string" }, "username": { "type": "string" }, "email": { "type": "string", "format": "email" } },
      "required": ["id", "username", "email"]
    },
    "Notification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Notification",
      "properties": { "id": { "type": "string" }, "userId": { "type": "string" }, "title": { "type": "string" }, "description": { "type": "string" }, "createdAt": { "type": "string", "format": "date-time" }, "read": { "type": "boolean" }, "link": { "type": "string" } },
      "required": ["id", "userId", "title", "description", "createdAt", "read"]
    },
    "SiteSettings": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "SiteSettings",
      "type": "object",
      "description": "Global settings for the website, like branding and content.",
      "properties": {
        "logoUrl": { "type": "string" },
        "faviconUrl": { "type": "string" },
        "heroBannerUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "backgroundColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "twitterUrl": { "type": "string" },
        "facebookUrl": { "type": "string" },
        "instagramUrl": { "type": "string" },
        "privacyPolicy": { "type": "string" },
        "termsAndConditions": { "type": "string" },
        "aboutUs": { "type": "string" }
      }
    }
  },
  "auth": { "providers": ["password", "anonymous"] },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" } } },
      { "path": "/vendors/{vendorId}", "definition": { "entityName": "Vendor", "schema": { "$ref": "#/backend/entities/Vendor" } } },
      { "path": "/events/{eventId}", "definition": { "entityName": "Event", "schema": { "$ref": "#/backend/entities/Event" } } },
      { "path": "/tickets/{ticketId}", "definition": { "entityName": "Ticket", "schema": { "$ref": "#/backend/entities/Ticket" } } },
      { "path": "/users/{userId}/tickets/{ticketId}", "definition": { "entityName": "UserTicket", "schema": { "$ref": "#/backend/entities/UserTicket" }, "description": "A subcollection for efficiently querying a user's tickets." } },
      { "path": "/roles_admin/{userId}", "definition": { "entityName": "Admin", "schema": { "$ref": "#/backend/entities/Admin" } } },
      { "path": "/users/{userId}/notifications/{notificationId}", "definition": { "entityName": "Notification", "schema": { "$ref": "#/backend/entities/Notification" } } },
      { "path": "/settings/site", "definition": { "entityName": "SiteSettings", "schema": { "$ref": "#/backend/entities/SiteSettings" }, "description": "A single document holding all global site settings." } }
    ],
    "reasoning": "The data model is now ticket-centric. Events are simple shells. A new root collection `/tickets/{ticketId}` holds all crafted ticket details, including design, pricing package, and validation rules. The `/users/{userId}/tickets` subcollection is a lightweight pointer to the main tickets for fast user-specific lookups. A new `/settings/site` document is added to store global configuration."
  }
}
