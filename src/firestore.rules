
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin role
    function isAdmin() {
      // A user is an admin if their UID is in the roles_admin collection.
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  
  	// Helper function to check if a user owns a document
    function isOwner(userId) {
    	return request.auth != null && request.auth.uid == userId;
    }

    // Helper to check if a user is upgrading to a vendor
    function isUpgradingToVendor(request, resource) {
      if (resource == null || resource.data.roles == null || request.resource.data.roles == null) {
        return false; // Can't be upgrading if docs or roles don't exist.
      }
      
      let oldRoles = resource.data.roles;
      let newRoles = request.resource.data.roles;
      
      // The only change allowed is adding 'vendor' to the existing roles.
      // 1. The new roles must contain all of the old roles.
      // 2. The new roles must be exactly one larger than the old roles.
      // 3. The new roles must include 'vendor'.
      // 4. The user cannot add the 'admin' role themselves.
      return newRoles.hasAll(oldRoles) &&
             newRoles.size() == oldRoles.size() + 1 &&
             newRoles.hasAny(['vendor']) &&
             // This prevents adding 'admin' if it wasn't there before.
             (oldRoles.hasAny(['admin']) || !newRoles.hasAny(['admin']));
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();
      // Allow user to create their own profile, but not assign roles.
      allow create: if isOwner(userId) && request.resource.data.roles.size() == 1 && request.resource.data.roles[0] == 'user';
      // Allow user to update their own profile, but not change their roles.
      // Admins can update roles.
      allow update: if isOwner(userId) && request.resource.data.roles == resource.data.roles || isAdmin();
    }
    
    // Users can read/write their own notifications.
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Users can read/write their own tickets.
    match /users/{userId}/tickets/{ticketId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /events/{eventId} {
       // Allow public list access for anyone, but the query must filter for 'published' status.
       allow list: if request.query.filters.hasAny(['status', '==', 'published']) || isAdmin();
       
       // Events are publicly readable only if they are published.
       // Vendors can read their own non-published events.
       // Admins can read all events regardless of status.
       allow read: if resource.data.status == 'published'
                    || (request.auth != null && resource.data.vendorId == request.auth.uid)
                    || isAdmin();

       // An authenticated user can create an event for themself.
       // An admin can create an event for anyone.
       allow create: if request.auth != null && request.resource.data.vendorId == request.auth.uid || isAdmin();
       
       // Events can be updated by their vendor owner or an admin.
       allow update: if isAdmin() || (request.auth != null && request.resource.data.vendorId == request.auth.uid);
       allow delete: if isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
    }
    
    match /categories/{categoryId} {
    	 allow read: if true;
       allow write: if isAdmin();
    }

    match /vendors/{vendorId} {
      // Admins can list all vendors.
      allow list: if isAdmin();
      // Any authenticated user can read a vendor profile.
      // Admins have full access.
      allow read: if request.auth != null || isAdmin();
      // Only a user can create their own vendor application document.
      allow create: if isOwner(vendorId);
      // Only the owner or an admin can update the vendor profile.
      allow update: if isOwner(vendorId) || isAdmin();
    }
    
    match /tickets/{ticketId} {
      // A user can read a ticket if they are the owner, or if they are the vendor for that event.
      // This rule also implicitly allows queries (like on the vendor dashboard) where every
      // document returned meets these conditions.
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth != null && resource.data.vendorId == request.auth.uid) || isAdmin();
      
      // Allow creation for any authenticated user
      allow create: if request.auth != null;
      
      // No updates or deletes from the client
      allow update, delete: if false;
    }
    
    // Admin role definitions are readable and writable by other admins.
    match /roles_admin/{userId} {
    	allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Site settings are publicly readable, but only writable by admins.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dataDeletionRequests/{requestId} {
      // Users can create their own deletion request.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Admins can manage all deletion requests.
      allow list, read, update: if isAdmin();
    }
  }
}
