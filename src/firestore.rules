
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper: Admin check ---
    // Checks the dedicated roles_admin collection OR the roles array on the user doc.
    function isAdmin() {
      return request.auth != null && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          "roles" in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin'])
        )
      );
    }

    // --- Helper: Document owner ---
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── /users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow list: if isAdmin();
      allow get:  if isOwner(userId) || isAdmin();

      // Users create their own document at sign-up.
      allow create: if isOwner(userId);

      // Admin can update anything. User can update own doc but NOT their own roles.
      allow update: if isAdmin() ||
                       (isOwner(userId) && request.resource.data.roles == resource.data.roles);

      allow delete: if isAdmin();
    }

    // ── /users/{userId}/notifications ────────────────────────────────────────
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── /users/{userId}/tickets (subcollection reference) ────────────────────
    match /users/{userId}/tickets/{ticketId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ── /events ──────────────────────────────────────────────────────────────
    match /events/{eventId} {
      // Public listing (client-side filtering by status happens in the app).
      allow list: if true;

      // Individual doc read: published events are public; owner or admin can read any.
      allow get: if resource.data.status == 'published'
                  || (request.auth != null && resource.data.vendorId == request.auth.uid)
                  || isAdmin();

      // Any authenticated user can create (vendor status enforced in app logic).
      allow create: if request.auth != null;

      // Only the owning vendor or admin can update/delete.
      allow update: if isAdmin() ||
                       (request.auth != null && resource.data.vendorId == request.auth.uid);
      allow delete: if isAdmin() ||
                       (request.auth != null && resource.data.vendorId == request.auth.uid);
    }

    // ── /categories ──────────────────────────────────────────────────────────
    match /categories/{categoryId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /vendors ─────────────────────────────────────────────────────────────
    match /vendors/{vendorId} {
      allow list:   if isAdmin();
      allow get:    if request.auth != null || isAdmin();
      // Vendor creates their own profile; admin can create/manage any.
      allow create: if isOwner(vendorId) || isAdmin();
      allow update: if isOwner(vendorId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── /tickets ─────────────────────────────────────────────────────────────
    match /tickets/{ticketId} {
      // Owner (attendee), vendor who created the ticket, or admin can read a single doc.
      allow get: if isAdmin() ||
                    (request.auth != null && (
                      resource.data.userId    == request.auth.uid ||
                      resource.data.vendorId  == request.auth.uid
                    ));

      // Public listing is needed so the event page can show ticket categories.
      allow list: if true;

      // Any authenticated user can purchase / create a ticket.
      allow create: if request.auth != null;

      // Ticket scanning: the vendor who owns the ticket or an authorised scanner
      // may increment `scans` / set `lastScannedAt`.  Only admin can do anything else.
      allow update: if isAdmin() ||
                       (request.auth != null && resource.data.vendorId == request.auth.uid) ||
                       (
                         request.auth != null &&
                         // Only allow touching the scan-related fields.
                         request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['scans', 'lastScannedAt'])
                       );

      allow delete: if isAdmin();
    }

    // ── /roles_admin ─────────────────────────────────────────────────────────
    // SECURITY: only existing admins may grant/revoke admin status.
    // A user may NOT write their own entry (that would be privilege escalation).
    match /roles_admin/{userId} {
      allow read:   if isAdmin();
      allow create,
            update,
            delete: if isAdmin();
    }

    // ── /settings ────────────────────────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── /withdrawalRequests ──────────────────────────────────────────────────
    // Vendors create requests for themselves.
    // `list` uses a `where('vendorId','==', uid)` query from the app; Firestore
    // evaluates `list` rules without document data, so we allow any authenticated
    // user to run the list and rely on the query filter + get rule for security.
    match /withdrawalRequests/{requestId} {
      allow create: if request.auth != null &&
                       request.resource.data.vendorId == request.auth.uid;
      allow get:    if isAdmin() ||
                       (request.auth != null && resource.data.vendorId == request.auth.uid);
      allow list:   if request.auth != null;
      allow update,
            delete: if isAdmin();
    }

    // ── /transactionAudits ───────────────────────────────────────────────────
    // Written server-side only (Firebase Admin SDK bypasses these rules).
    // Client-side reads are admin-only.
    match /transactionAudits/{auditId} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update,
            delete: if false;
    }

    // ── /dataDeletionRequests ────────────────────────────────────────────────
    match /dataDeletionRequests/{requestId} {
      allow create: if request.auth != null &&
                       request.resource.data.userId == request.auth.uid;
      allow list, get,
            update, delete: if isAdmin();
    }
  }
}
