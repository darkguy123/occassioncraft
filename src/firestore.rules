
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin role
    function isAdmin() {
      // A user is an admin if their UID is in the roles_admin collection.
      return (request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)));
    }
  
  	// Helper function to check if a user owns a document
    function isOwner(userId) {
    	return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow read: if isOwner(userId) || isAdmin();

      // A user can create their own document when signing up.
      allow create: if isOwner(userId);

      // An admin can update any user document.
      // A user can update their own document, BUT they cannot change their own roles.
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.roles == resource.data.roles);
    }
    
    // Users can read/write their own notifications.
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Users can read/write their own tickets.
    match /users/{userId}/tickets/{ticketId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /events/{eventId} {
       // Allow anyone to attempt to list events. The 'get' rule below will filter the results.
       allow list: if true;
       
       // Secure individual document reads.
       // Events are publicly readable only if they are published.
       // Vendors can read their own non-published events.
       // Admins can read all events regardless of status.
       allow get: if resource.data.status == 'published'
                    || (request.auth != null && resource.data.vendorId == request.auth.uid)
                    || isAdmin();

       // Events can be created by an authenticated user.
       // Events can be updated by their vendor owner or an admin.
       allow create: if request.auth != null;
       allow update: if isAdmin() || (request.auth != null && request.resource.data.vendorId == request.auth.uid);
       allow delete: if isAdmin() || (request.auth != null && resource.data.vendorId == request.auth.uid);
    }
    
    match /categories/{categoryId} {
    	 allow read: if true;
       allow write: if isAdmin();
    }

    match /vendors/{vendorId} {
      // Admins can list all vendors.
      allow list: if isAdmin();
      // Any authenticated user can read a vendor profile (since all are vendors)
      // Admins have full access.
      allow read: if request.auth != null || isAdmin();
      // Only users can create their own vendor profile at signup, and admins can write to any.
      allow create: if isOwner(vendorId);
      // Only the owner or an admin can update the vendor profile.
      allow update: if isOwner(vendorId) || isAdmin();
    }
    
    match /tickets/{ticketId} {
      // A user can read a single ticket if they are the owner, the vendor, or an admin.
      allow get: if (request.auth != null && (resource.data.userId == request.auth.uid || resource.data.vendorId == request.auth.uid)) || isAdmin();
      
      // Allow authenticated users to LIST tickets. The 'get' rule above will secure access.
      allow list: if request.auth != null;

      // Allow creation for any authenticated user
      allow create: if request.auth != null;
      
      // No updates or deletes from the client
      allow update, delete: if false;
    }
    
    // Admin role definitions are readable and writable by other admins, or a user creating their own.
    match /roles_admin/{userId} {
    	allow read: if isAdmin();
      allow write: if isAdmin() || isOwner(userId);
    }
    
    // Site settings are publicly readable, but only writable by admins.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /dataDeletionRequests/{requestId} {
      // Users can create their own deletion request.
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Admins can manage all deletion requests.
      allow list, read, update: if isAdmin();
    }
  }
}
