
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin role
    function isAdmin() {
      return request.auth != null && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
  
  	// Helper function to check if a user owns a document
    function isOwner(userId) {
    	return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      // Admins can list all users.
      allow list: if isAdmin();
      // Users can read and write their own profile data. Admins can read/write any user's data.
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    // Users can read/write their own notifications.
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Users can read/write their own tickets.
    match /users/{userId}/tickets/{ticketId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /events/{eventId} {
       // Allow public list access for anyone. The query must filter for 'published' status on the client.
       allow list: if true;
       
       // Events are publicly readable only if they are published.
       // Vendors can read their own non-published events.
       // Admins can read all events regardless of status.
       allow read: if resource.data.status == 'published'
                    || (request.auth != null && resource.data.vendorId == request.auth.uid)
                    || isAdmin();

       // Events can be created by a vendor.
       // Events can be updated by their vendor owner or an admin.
       allow write: if isAdmin() || (request.auth != null && request.resource.data.vendorId == request.auth.uid);
    }
    
    match /categories/{categoryId} {
    	 allow read: if true;
       allow write: if isAdmin();
    }

    match /vendors/{vendorId} {
      // Admins can list all vendors.
      allow list: if isAdmin();
      // Vendors can read and write their own profiles. Admins have full access.
      allow read, write: if isOwner(vendorId) || isAdmin();
    }
    
    match /tickets/{ticketId} {
      // Admins can list all tickets
      allow list: if isAdmin();
      // A user can read a ticket if they are the owner, or if they are the vendor for that event
      allow read: if (request.auth != null && resource.data.userId == request.auth.uid) || (request.auth != null && resource.data.vendorId == request.auth.uid) || isAdmin();
      // Allow creation for any authenticated user
      allow create: if request.auth != null;
      // No updates or deletes from the client
      allow update, delete: if false;
    }
    
    // Admin role definitions are readable and writable by other admins, or a user creating their own.
    match /roles_admin/{userId} {
    	allow read: if isAdmin();
      allow write: if isAdmin() || isOwner(userId);
    }
    
    // Site settings are publicly readable, but only writable by admins.
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
