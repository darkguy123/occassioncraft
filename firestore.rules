
/**
 * @file Firebase Security Rules for Firestore.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user and vendor ownership model, supplemented by admin roles, to control access to data. Users and vendors can only access their own data, while admins have broader privileges.
 *
 * Data Structure:
 * - User profiles are stored under `/users/{userId}`.
 * - Vendor profiles are stored under `/vendors/{vendorId}`.
 * - Events are stored under `/vendors/{vendorId}/events/{eventId}`.
 * - Tickets are stored under `/users/{userId}/tickets/{ticketId}`.
 * - Categories are stored under `/categories/{categoryId}`.
 * - Ticket templates are stored under `/ticket_templates/{ticketTemplateId}`.
 * - Admin roles are indicated by the presence of a document under `/roles_admin/{userId}`.
 * - Notifications are stored under `/users/{userId}/notifications/{notificationId}`.
 *
 * Key Security Decisions:
 * - Admins have full read/write access to all data.
 * - Users and vendors can only create, read, update, and delete their own profiles and associated resources (events, tickets, notifications).
 * - Public read access is granted to `approved` events, categories, and ticket templates.
 *
 * Denormalization for Authorization:
 *  To ensure authorization independence, event documents under `/vendors/{vendorId}/events/{eventId}` should contain a denormalized `vendorId` field, mirroring the `vendorId` in the path.  Similarly, ticket documents under `/users/{userId}/tickets/{ticketId}` should contain denormalized `userId` and `eventId` fields. This allows rules to validate ownership without additional `get()` operations.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     * @path N/A
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided userId.
     * @path NA
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user's ID matches the resource's vendorId.
     * @path N/A
     */
    function isVendorOwner(vendorId) {
      return request.auth.uid == vendorId;
    }

    /**
     * @description Checks if the authenticated user has admin privileges by verifying the existence of a document in the roles_admin collection.
     * @path N/A
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Checks if the authenticated user is the owner of an existing document.
     * @path N/A
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the authenticated vendor is the owner of an existing document.
     * @path N/A
     */
     function isExistingVendorOwner(vendorId) {
        return isVendorOwner(vendorId) && resource != null;
    }

    /**
     * @description Rule for user profiles.
     * @path /users/{userId}
     * @principle Enforces document ownership for non-admins, grants full access to admins.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description Rule for vendor profiles.
     * @path /vendors/{vendorId}
     * @principle Enforces document ownership for non-admins, grants full access to admins.
     */
    match /vendors/{vendorId} {
      allow get, list: if isVendorOwner(vendorId) || isAdmin();
      allow create: if (isVendorOwner(vendorId) || isAdmin()) && request.resource.data.id == vendorId;
      allow update, delete: if isVendorOwner(vendorId) || isAdmin();
    }

    /**
     * @description Rule for events created by vendors.
     * @path /vendors/{vendorId}/events/{eventId}
     * @principle Public can read approved events. Vendors can manage their own events. Admins have full access.
     */
     match /vendors/{vendorId}/events/{eventId} {
      allow get: if resource.data.status == 'approved' || isVendorOwner(vendorId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isVendorOwner(vendorId) || isAdmin()) && request.resource.data.vendorId == vendorId;
      allow update, delete: if isVendorOwner(vendorId) || isAdmin();
    }

    /**
     * @description Rule for tickets purchased by users.
     * @path /users/{userId}/tickets/{ticketId}
     * @principle Enforces document ownership for non-admins, grants full access to admins.
     */
    match /users/{userId}/tickets/{ticketId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    /**
     * @description Rule for event categories.
     * @path /categories/{categoryId}
     * @principle Public read, admin-only write for categories.
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rule for ticket templates.
     * @path /ticket_templates/{ticketTemplateId}
     * @principle Public read, admin-only write for ticket templates.
     */
    match /ticket_templates/{ticketTemplateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

      /**
     * @description Rule for admin privileges.
     * @path /roles_admin/{userId}
     * @principle Admin-only access to manage admin roles.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Rule for user notifications.
     * @path /users/{userId}/notifications/{notificationId}
     * @principle Enforces strict ownership for non-admins. Grants full access to admins.
     */
    match /users/{userId}/notifications/{notificationId} {
      allow get, list: if isOwner(userId) || isAdmin();
      // Allow server-side or admin creation
      allow create: if isAdmin();
      allow update: if (isOwner(userId) && request.resource.data.keys().hasOnly(['read'])) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
    }
  }
}
