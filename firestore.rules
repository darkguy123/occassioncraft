/**
 * @fileOverview Firestore Security Rules for OccasionCraft.
 *
 * Core Philosophy:
 * This ruleset enforces a role-based access control model, with distinctions between regular users, event vendors, and administrators. User ownership is strictly enforced for personal data, and vendor ownership is enforced for events. Admin privileges are managed through a dedicated collection.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, with 'userType' indicating role.
 * - /vendors/{vendorId}: Stores vendor profiles, linked to users via 'userId'.
 * - /vendors/{vendorId}/events/{eventId}: Stores event data, nested under the vendor who created it.
 * - /users/{userId}/tickets/{ticketId}: Stores ticket purchases, nested under the user who bought them.
 * - /roles_admin/{userId}: Presence of a document indicates admin status for the user.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user profiles.
 * - Vendors can only manage events they create.
 * - Admins have broad access, determined by document existence in /roles_admin/{userId}.
 * - Listing all users is disallowed.
 *
 * Denormalization for Authorization:
 * - User roles are stored directly in the /users/{userId} document ('userType' field) to avoid costly lookups.
 * - Event documents store the 'vendorId' to enforce vendor ownership without additional reads.
 *
 * Structural Segregation:
 * - Admin status is managed in a separate collection (/roles_admin/{userId}) to avoid adding a boolean flag to the User document. This makes admin role checks efficient and avoids accidental privilege escalation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user ID matches the provided user ID.
     * @param {string} userId - The user ID to compare against.
     * @returns {boolean} True if the user is signed in and the user IDs match, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is an existing owner of the document.
     * @param {string} userId - The user ID to compare against.
     * @returns {boolean} True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the user is an admin. This function reads from the /roles_admin/{userId} collection.
     * @returns {boolean} True if the user has an admin document, false otherwise.
     */
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /**
     * @description Rules for user profiles.
     * @path /users/{userId}
     * @allow (create) - User 'user_abc' can create their profile if authenticated and the ID matches.
     *     request.auth.uid: 'user_abc', request.resource.data.id: 'user_abc'
     * @allow (get, update, delete) - User 'user_abc' can read/update/delete their profile if authenticated and the ID matches.
     *     request.auth.uid: 'user_abc', resource.data.id: 'user_abc'
     * @deny (create) - User 'user_xyz' cannot create a profile for 'user_abc'.
     *     request.auth.uid: 'user_xyz', request.resource.data.id: 'user_abc'
     * @deny (update, delete) - User 'user_xyz' cannot update/delete the profile of 'user_abc'.
     *     request.auth.uid: 'user_xyz', resource.data.id: 'user_abc'
     * @principle Enforces document ownership for writes, restricts access to a user's own data tree.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for vendor profiles.
     * @path /vendors/{vendorId}
     * @allow (create) - Anyone can create a vendor profile.
     * @allow (get) - Anyone can read a vendor profile.
     * @allow (update, delete) - Only admins can update or delete vendor profiles.
     * @deny (update, delete) - Non-admins cannot update or delete vendor profiles.
     * @principle Allows public read access, restricts updates/deletes to admins.
     */
    match /vendors/{vendorId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    /**
     * @description Rules for events created by vendors.
     * @path /vendors/{vendorId}/events/{eventId}
     * @allow (get, list) - Anyone can read events.
     * @allow (create) - Only the vendor can create an event. The vendorId must match the path.
     * @allow (update, delete) - Only the vendor or an admin can update/delete their events.
     * @deny (create) - User 'user_xyz' cannot create an event for vendor 'vendor_abc'.
     *     request.auth.uid: 'user_xyz', resource.data.vendorId: 'vendor_abc'
     * @deny (update, delete) - User 'user_xyz' cannot update/delete event 'event_123' for vendor 'vendor_abc'.
     *     request.auth.uid: 'user_xyz', resource.data.vendorId: 'vendor_abc'
     * @principle Enforces vendor ownership for event management, allows public read access.
     */
    match /vendors/{vendorId}/events/{eventId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.vendorId == vendorId && exists(/databases/$(database)/documents/vendors/$(vendorId));
      allow update, delete: if (isAdmin() || (isSignedIn() && request.auth.uid == resource.data.vendorId && exists(/databases/$(database)/documents/vendors/$(vendorId))));
    }

    /**
     * @description Rules for tickets purchased by users.
     * @path /users/{userId}/tickets/{ticketId}
     * @allow (get, list) - Only the user can read/list their own tickets.
     * @allow (create) - Only the user can create tickets under their ID. userId on path must match request auth uid.
     * @allow (update, delete) - Only the user can update/delete their own tickets.
     * @deny (create) - User 'user_xyz' cannot create tickets for 'user_abc'.
     *     request.auth.uid: 'user_xyz', request.resource.data.userId: 'user_abc'
     * @deny (update, delete) - User 'user_xyz' cannot update/delete ticket 'ticket_123' for user 'user_abc'.
     *     request.auth.uid: 'user_xyz', resource.data.userId: 'user_abc'
     * @principle Enforces user ownership for ticket management.
     */
    match /users/{userId}/tickets/{ticketId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update, delete: if isExistingOwner(userId) && request.resource.data.userId == userId;
    }

    /**
     * @description Rules for admin roles, based on document existence.
     * @path /roles_admin/{userId}
     * @allow (get, list) - Only admins can check the admin status of other users.
     * @allow (create) - Only admins can assign admin roles.
     * @allow (update, delete) - Only admins can modify the admin role collection.
     * @deny (create, update, delete) - Non-admins cannot create, update, or delete admin roles.
     * @principle Restricts admin role management to existing admins.
     */
    match /roles_admin/{userId} {
      allow get, list: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}