
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @file Firebase Security Rules for Firestore.
     *
     * Core Philosophy:
     * This ruleset enforces a strict user and vendor ownership model, supplemented by admin roles, to control access to data. Users and vendors can only access their own data, while admins have broader privileges.
     *
     * Data Structure:
     * - User profiles are stored under `/users/{userId}`.
     * - Vendor profiles are stored under `/vendors/{vendorId}`.
     * - Events are stored under `/vendors/{vendorId}/events/{eventId}`.
     * - Tickets are stored under `/users/{userId}/tickets/{ticketId}`.
     * - Categories are stored under `/categories/{categoryId}`.
     * - Ticket templates are stored under `/ticket_templates/{ticketTemplateId}`.
     * - Admin roles are indicated by the presence of a document under `/roles_admin/{userId}`.
     * - Notifications are stored under `/users/{userId}/notifications/{notificationId}`.
     * - Wallets are stored at `/wallets/{userId}`.
     * - Transactions are stored in a subcollection under each wallet.
     *
     * Key Security Decisions:
     * - Admins have full read/write access to all data.
     * - Users and vendors can only create, read, update, and delete their own profiles and associated resources (events, tickets, notifications).
     * - Public read access is granted to `approved` events, categories, and ticket templates.
     *
     * Denormalization for Authorization:
     *  To ensure authorization independence, event documents under `/vendors/{vendorId}/events/{eventId}` should contain a denormalized `vendorId` field, mirroring the `vendorId` in the path.  Similarly, ticket documents under `/users/{userId}/tickets/{ticketId}` should contain denormalized `userId` and `eventId` fields. This allows rules to validate ownership without additional `get()` operations.
     */

    /**
     * ────────────────────────────────────────────────
     * 🔧 Utility Functions
     * ────────────────────────────────────────────────
     */

    // Check if a user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Check if a user owns a document by matching their UID
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Check if the authenticated user is an admin by checking for a role document
    function isAdmin() {
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }


    /**
     * ────────────────────────────────────────────────
     * 👤 User Profiles
     * ────────────────────────────────────────────────
     */
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🏢 Vendor Profiles
     * ────────────────────────────────────────────────
     */
    match /vendors/{vendorId} {
      allow read, write: if isOwner(vendorId) || isAdmin();
      allow list: if isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🎟️ Events (under each vendor)
     * ────────────────────────────────────────────────
     */
    match /vendors/{vendorId}/events/{eventId} {
      // Public can read approved events. Owners and Admins can read any event.
      allow get: if resource.data.status == 'approved' || isOwner(vendorId) || isAdmin();
      
      // An event can be created if the user is the vendor OR is an admin.
      allow create: if isOwner(vendorId) || isAdmin();

      // An event can be updated/deleted if the user is the vendor OR is an admin.
      allow update, delete: if isOwner(vendorId) || isAdmin();
    }
    
    /**
     * ────────────────────────────────────────────────
     * 🎫 Tickets (under each user)
     * ────────────────────────────────────────────────
     */
    match /users/{userId}/tickets/{ticketId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🏷️ Categories (publicly visible, admin-managed)
     * ────────────────────────────────────────────────
     */
    match /categories/{categoryId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🧾 Ticket Templates (public read, admin write)
     * ────────────────────────────────────────────────
     */
    match /ticket_templates/{ticketTemplateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🛡️ Admin Role Management
     * ────────────────────────────────────────────────
     */
    match /roles_admin/{userId} {
      allow read, write: if isAdmin();
      allow list: if isAdmin();
    }

    /**
     * ────────────────────────────────────────────────
     * 🔔 User Notifications
     * ────────────────────────────────────────────────
     */
    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    /**
     * ────────────────────────────────────────────────
     * 💰 Wallets & Transactions
     * ────────────────────────────────────────────────
     */
    match /wallets/{userId} {
      // User can read their own wallet. Admins can read any.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can create/update a wallet document to protect the balance.
      allow create, update: if isAdmin();
      // Admin can list all wallets.
      allow list: if isAdmin();
    }

    match /wallets/{userId}/transactions/{transactionId} {
      // User can read their own transactions. Admins can read any.
      allow get, list: if isOwner(userId) || isAdmin();
      // Only admins or a secure backend process should create transactions.
      // For this app, we'll allow admins to create them.
      allow create: if isAdmin();
    }
    
    /**
     * ────────────────────────────────────────────────
     * 🌐 Collection Group Queries
     * ────────────────────────────────────────────────
     */
     
    // This rule allows the public homepage to query for approved events across all vendors.
    // It also allows admins to list all events for the admin panel.
    match /{path=**}/events/{eventId} {
       allow list: if request.query.get('status') == 'approved' || isAdmin();
    }
    
    // This rule allows admins to query for any ticket across all users,
    // which is necessary for the main admin tickets view.
    match /{path=**}/tickets/{ticketId} {
       allow list: if isAdmin();
    }
  }
}
