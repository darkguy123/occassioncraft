rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for user profile images
    match /users/{userId}/profile.jpg {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Rules for event images
    match /vendors/{vendorId}/events/{eventId}/event_image.jpg {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/vendors/$(vendorId)) &&
                   /databases/$(database)/documents/vendors/$(vendorId).data.userId == request.auth.uid;
    }

    // Rules for vendor logos
    match /vendors/{vendorId}/logo.jpg {
      allow read: if true;
      allow write: if exists(/databases/$(database)/documents/vendors/$(vendorId)) &&
                   /databases/$(database)/documents/vendors/$(vendorId).data.userId == request.auth.uid;
    }
  }
}

    