rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read access to all files so they can be displayed in the app.
      allow read;
      
      // Allow any authenticated user to upload (write) files.
      // The application code ensures files are uploaded to appropriate paths.
      allow write: if request.auth != null;
    }
  }
}
