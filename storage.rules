
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Public assets are readable by anyone.
    match /public/{allPaths=**} {
      allow read;
    }

    // Any file inside a folder named with a user's ID can only be written to by that user.
    // This covers /banners/{userId}, /ticket-assets/{userId}, and /avatars/{userId}.
    // Files are publicly readable after upload.
    match /{path}/{userId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
