
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Rules for user profile images
    // Users can read anyone's profile image, but can only write to their own.
    match /users/{userId}/profile.jpg {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Rules for public assets uploaded by admin
    // Anyone can read these assets, but only authenticated users (admins) can write them.
    match /public/assets/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}

    