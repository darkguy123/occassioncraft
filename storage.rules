
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow public read access for all files.
    allow read;

    // Any authenticated user can write to the "public-uploads" folder.
    // The use of UUIDs in filenames by the app prevents collisions.
    // Deletion is disallowed from the client to prevent malicious or accidental removal.
    match /public-uploads/{allPaths=**} {
      allow write: if request.auth != null;
      allow delete: if false; 
    }
  }
}
