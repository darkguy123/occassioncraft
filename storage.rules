
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Public assets are readable by anyone.
    match /public/{allPaths=**} {
      allow read: if true;
    }

    // User-uploaded banners are publicly readable but only writable by the owner.
    match /banners/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // User-uploaded ticket assets are publicly readable but only writable by the owner.
    match /ticket-assets/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // User-uploaded avatars are publicly readable but only writable by the owner.
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
