
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Default rule: Allow read access to everyone for all files.
    // This ensures that any uploaded image (by admins, vendors, or users)
    // can be displayed on the frontend to any visitor.
    // Write access is restricted to authenticated users to prevent anonymous uploads.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
