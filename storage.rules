rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Allow any authenticated vendor, user, or admin to upload images up to 5MB anywhere in public-uploads
    // Allow anyone to read these uploaded files
    match /public-uploads/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Default deny for all other paths to secure the rest of your storage bucket
    match /{allPaths=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
