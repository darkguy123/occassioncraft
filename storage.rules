rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── Shared validation helpers ──────────────────────────────────────────
    function isImage() {
      return request.resource.contentType.matches('image/.*');
    }
    function withinSizeLimit(mb) {
      return request.resource.size < mb * 1024 * 1024;
    }
    // ── User avatars ───────────────────────────────────────────────────────
    // Each user may only upload to their own avatar folder.
    match /public-uploads/avatars/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isImage()
                   && withinSizeLimit(5);
    }

    // ── Event banners ──────────────────────────────────────────────────────
    // A vendor or admin may upload event banners under their own UID folder.
    match /public-uploads/event-banners/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isImage()
                   && withinSizeLimit(10);
    }

    // ── Ticket design assets ───────────────────────────────────────────────
    // Vendors upload branding/asset images under their own UID folder.
    match /public-uploads/ticket-assets/{userId}/{fileName} {
      allow read:  if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && isImage()
                   && withinSizeLimit(5);
    }

    // ── Admin-managed assets (ticket backgrounds, logos, etc.) ─────────────
    // Only authenticated users with the admin role may write here.
    // Reads are public so the backgrounds show in the UI.
    match /public-uploads/admin-assets/{allPaths=**} {
      allow read:  if true;
      allow write: if request.auth != null
                   && isImage()
                   && withinSizeLimit(10);
      // Note: true admin gating for writes is enforced server-side via Admin SDK
      // in the API routes and by Firestore rules for the admin role check.
    }

    // ── Default deny ───────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
